# Build directories
build/
cmake-build-*/
out/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Windows Zone.Identifier files
*:Zone.Identifier

# Compiled objects
*.o
*.obj
*.a
*.lib
*.so
*.dylib

# Executables
*.exe
*.out

# VTK output files (simulation results)
*.vtk
*.vtu
*.pvd
visualization_output/
test_output/

# Temporary files
*.tmp
*.temp
*.log

# Analysis tools
.VSCodeCounter/

# Python cache
__pycache__/
*.pyc

# Core dumps (only in root, not src/core/ or include/core/)
/core
/core.*

# CUDA compiled files
*.cubin
*.fatbin
*.ptx

# Documentation builds (keep source)
docs/_build/

# Large data files
*.dat
*.bin
*.raw

# Keep important markdown docs
!README.md
!CLAUDE.md
!ARCHITECTURE.md
!docs/*.md

# Gemini/Claude specific files
.claude/

# Python virtual environment
venv/

# Backup files
*.backup*
*.bak

# Generated Documentation & Reports
# Ignore all markdown and text files by default
*.md
*.txt
*.pdf

# Then, un-ignore the ones that are explicitly tracked or should be.
# This is a more maintainable approach than listing all reports.
!README.md
!README_DOCS.md
!CLAUDE.md
!ARCHITECTURE.md
!CMakeLists.txt
!LBM_Framework_Blueprint.json
!MATERIAL_DATABASE.yaml
!*.sh

# Un-ignore documentation source files
!docs/**/*.md

# Test executables in root (not source files)
# NOTE: Do NOT ignore test_*.cu — those are test source files in tests/
/test_*
!/tests/

# Output directories (simulation results — large, reproducible)
output_*/
presentation_figures/
test_reports/
backups/
Testing/

# Config files (assuming they are for specific tests and not part of the core config)
/configs/

# Generated images and templates
*.png
*.template

# Build directories
build_test/
benchmark/
build_check/
